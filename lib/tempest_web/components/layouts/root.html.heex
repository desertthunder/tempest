<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content={site_description()} />
    <link rel="canonical" href={public_url()} />
    <meta property="og:site_name" content={site_name()} />
    <meta property="og:title" content={site_title(assigns)} />
    <meta property="og:description" content={site_description()} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={public_url()} />
    <meta property="og:image" content={public_url(~p"/images/og.png")} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Tempest PDS" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={site_title(assigns)} />
    <meta name="twitter:description" content={site_description()} />
    <meta name="twitter:image" content={public_url(~p"/images/og.png")} />
    <meta name="twitter:image:alt" content="Tempest PDS" />
    <.live_title default="Tempest PDS" suffix=" · AT Protocol">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="icon" href={~p"/favicon.svg"} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={~p"/favicon.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
