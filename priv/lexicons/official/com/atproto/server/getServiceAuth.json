{
  "lexicon": 1,
  "id": "com.atproto.server.getServiceAuth",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a short-lived service-auth token for a constrained audience and Lexicon method.",
      "parameters": {
        "type": "params",
        "required": ["aud", "lxm"],
        "properties": {
          "aud": { "type": "string", "description": "Token audience." },
          "lxm": { "type": "string", "format": "nsid", "description": "Lexicon method this token may be used with." }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": { "type": "object", "required": ["token"], "properties": { "token": { "type": "string" } } }
      }
    }
  }
}
